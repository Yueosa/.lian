plan.md

# example: 测试文件
example

# VS Code 工作区设置（个人）
.vscode/

# ============================================================
# Agent 工作目录 / 隐私文件
# ============================================================

# claude code / codex 等 agent 在仓库根或子目录留下的元数据（文件或目录都忽略）
.claude
.codex
**/.codex
**/.claude

# secrets
.env

# ============================================================
# 个人化资源（其他用户应自行准备）
# ============================================================

# 我机器上的 fastfetch logo 是个人收藏，不公开
fastfetch/logo

# GTK 书签是本地路径
gtk-3.0/bookmarks

# ============================================================
# 由程序运行时生成的缓存 / 状态
# ============================================================

# Python 字节码
__pycache__/
*.pyc

# nvim lazy-lock：每次插件升级都会变，按个人习惯不入库
lazy-lock.json

# fcitx5 rime 自动生成的快照/缓存，以及个人词库
fcitx5/rime/*_cleanup_*.txt
fcitx5/rime/worddb_snapshot_*.txt
fcitx5/rime/custom_phrase.txt

# 动态切换主题（matugen 在运行时写出的成品，模板在 matugen/templates/ 下不受影响）
/gtk-3.0/gtk.css
/gtk-4.0/gtk.css
